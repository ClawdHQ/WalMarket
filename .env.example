# Copy this file to .env at the repo root (apps/web/.env and apps/demo-agent/.env
# are symlinks to it — see README "Monorepo env setup"). Never commit the real .env.

# ── Sui network ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUI_NETWORK=testnet

# ── WalMarket contracts (set after `pnpm publish:contracts`) ────────────────
# Original package ID — required for event/struct type queries (Sui ties type
# identity to the *defining* package, never the latest upgrade).
NEXT_PUBLIC_WALMARKET_PACKAGE_ID=
# Most recent package ID after any `sui client upgrade` — required for moveCall
# targets that need post-upgrade functions. Equal to the package ID until the
# first upgrade.
NEXT_PUBLIC_WALMARKET_LATEST_PACKAGE_ID=
# WalMarketRegistry shared object ID from the publish output.
NEXT_PUBLIC_WALMARKET_REGISTRY_ID=

# ── MemWal (Walrus Memory) ───────────────────────────────────────────────────
NEXT_PUBLIC_MEMWAL_PACKAGE_ID=0xcf6ad755a1cdff7217865c796778fabe5aa399cb0cf2eba986f4b582047229c6
NEXT_PUBLIC_MEMWAL_REGISTRY_ID=0xe80f2feec1c139616a86c9f71210152e2a7ca552b20841f2e192f99f75864437
NEXT_PUBLIC_MEMWAL_RELAYER_URL=https://relayer-staging.memory.walrus.xyz
MEMWAL_RELAYER_URL=https://relayer-staging.memory.walrus.xyz

# Self-hosted seller agent identity (apps/demo-agent) — see its README. Only
# needed if you run a self-hosted seller agent yourself; the "let WalMarket
# handle it" managed-seller path on /sell needs none of this from you.
MEMWAL_PRIVATE_KEY=
MEMWAL_ACCOUNT_ID=

# ── Walrus (blob storage / Walrus Sites) ─────────────────────────────────────
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space

# ── Auth (zkLogin via Mysten Enoki) ──────────────────────────────────────────
# console.enoki.mystenlabs.com — create a project, add a Google OAuth client,
# register http://localhost:3000/auth/callback (and your prod domain) as an
# authorized redirect URI.
NEXT_PUBLIC_ENOKI_API_KEY=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Managed-seller custody (apps/web) ────────────────────────────────────────
# AES-256-GCM key (32 bytes hex) encrypting WalMarket-managed sellers' MemWal
# account keys at rest in apps/web/.data/managed-agents.db. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MANAGED_AGENT_ENCRYPTION_KEY=
# Funds every freshly-provisioned managed-seller keypair with 0.2 testnet SUI
# so it can pay its own gas. Falls back to MEMWAL_PRIVATE_KEY if unset — fine
# for a demo, but a real deployment should use its own monitored treasury key.
WALMARKET_TREASURY_PRIVATE_KEY=

# ── Demo agent / AI ──────────────────────────────────────────────────────────
# Used by apps/demo-agent's seeder for nothing on-chain — MemWal's own relayer
# does the embedding/LLM work server-side. Only needed if you extend the demo
# agent with your own LLM calls.
OPENAI_API_KEY=
